{
  "name": "bugrit-billing-function",
  "version": "1.0.0",
  "description": "Cloud Function for GCP billing data queries",
  "main": "index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "deploy": "gcloud functions deploy gcpBilling --gen2 --runtime=nodejs20 --trigger-http --allow-unauthenticated --entry-point=gcpBilling --source=. --region=us-central1"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.3.0",
    "@google-cloud/functions-framework": "^3.3.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0"
  }
}
