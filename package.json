{
  "name": "bugrit",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "next dev --turbopack -p 9002",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' NODE_ENV=production next build",
    "build:worker": "tsc worker/server.ts --outDir worker/dist --esModuleInterop --resolveJsonModule --skipLibCheck",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy:worker": "npx ts-node scripts/deploy-worker.ts",
    "worker:dev": "npx ts-node worker/server.ts",
    "deploy": "npm run build && firebase deploy --only hosting",
    "deploy:firebase": "firebase deploy",
    "deploy:firestore": "firebase deploy --only firestore",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:cloudrun": "gcloud builds submit --config cloudbuild.yaml",
    "deploy:apphosting": "firebase apphosting:backends:deploy bugrit",
    "emulators": "firebase emulators:start",
    "emulators:firestore": "firebase emulators:start --only firestore",
    "setup:secrets": "npx ts-node scripts/setup-secrets.ts"
  },
  "dependencies": {
