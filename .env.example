# =============================================================================
# BUGRIT ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local or any file containing real credentials
# =============================================================================

# =============================================================================
# FIREBASE ADMIN (required)
# =============================================================================
# Service account key for Firebase Admin SDK
# Get this from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Paste the entire JSON object as a single line
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Firebase Project ID (alternative to service account for some operations)
FIREBASE_PROJECT_ID=your-firebase-project-id

# =============================================================================
# SECURITY (required in production)
# =============================================================================
# 32-character encryption key for admin data encryption
# Generate with: openssl rand -hex 16
ADMIN_ENCRYPTION_KEY=generate-secure-32-character-key-here

# Email address for primary superadmin access
SUPERADMIN_EMAIL=admin@yourdomain.com

# Comma-separated list of protected superadmin emails (optional)
# These emails cannot be removed from admin access via the admin panel
PROTECTED_SUPERADMIN_EMAILS=admin@yourdomain.com

# Admin API key for server-to-server authentication (optional)
ADMIN_API_KEY=

# =============================================================================
# STRIPE BILLING — LIVE keys (used when BUGRIT_ENVIRONMENT=production / bugrit.com)
# =============================================================================
# Get these from Stripe Dashboard > Developers > API keys (Live mode)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs for subscription tiers (Live mode)
STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_YEARLY_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_BUSINESS_MONTHLY_PRICE_ID=price_...
STRIPE_BUSINESS_YEARLY_PRICE_ID=price_...

# =============================================================================
# STRIPE BILLING — TEST/SANDBOX keys (used on all non-production URLs)
# =============================================================================
# The app auto-selects test vs live keys based on hostname.
# bugrit.com = live. Everything else = test (sandbox).
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_TEST_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_TEST_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs for subscription tiers (Test mode)
STRIPE_TEST_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_TEST_STARTER_YEARLY_PRICE_ID=price_...
STRIPE_TEST_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_TEST_PRO_YEARLY_PRICE_ID=price_...
STRIPE_TEST_BUSINESS_MONTHLY_PRICE_ID=price_...
STRIPE_TEST_BUSINESS_YEARLY_PRICE_ID=price_...

# =============================================================================
# APP URLS (required)
# =============================================================================
# Your application's public URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# =============================================================================
# FIREBASE CLIENT SDK (required for client-side auth)
# =============================================================================
# Get these from Firebase Console > Project Settings > General > Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# =============================================================================
# MONITORING & OBSERVABILITY (optional)
# =============================================================================
# Sentry error tracking
# Get from Sentry Dashboard > Settings > Projects > Client Keys
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_URL=https://sentry.io

# OpenTelemetry / Distributed tracing
OTEL_EXPORTER_OTLP_ENDPOINT=
JAEGER_URL=
TEMPO_URL=

# =============================================================================
# GITHUB INTEGRATION (optional)
# =============================================================================
# For GitHub repository analysis features
# Personal access token or GitHub App credentials
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# =============================================================================
# ANALYTICS (optional)
# =============================================================================
# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...

# Facebook Pixel
NEXT_PUBLIC_FB_PIXEL_ID=

# =============================================================================
# EMAIL NOTIFICATIONS (optional)
# =============================================================================
# Resend API for transactional emails
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# =============================================================================
# GOOGLE CLOUD (required for Docker-based scanning tools)
# =============================================================================
# GCP Project ID where Cloud Build runs
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Cloud Storage bucket for scan artifacts (defaults to ${PROJECT_ID}-bugrit-scans)
SCAN_OUTPUT_BUCKET=your-project-bugrit-scans

# Service account for Cloud Build (optional, uses default if not set)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# =============================================================================
# SCAN WORKER (required for browser-based tools like Lighthouse, axe-core)
# =============================================================================
# Cloud Run URL for the scan worker service
# Deploy the worker from /worker directory, then set this URL
SCAN_WORKER_URL=https://bugrit-scan-worker-xxxxx-uc.a.run.app

# Shared secret for worker authentication
# Generate with: openssl rand -base64 32
WORKER_SECRET=generate-secure-shared-secret-here

# =============================================================================
# THIRD-PARTY INTEGRATIONS (optional)
# =============================================================================
# SonarQube code quality
SONARQUBE_URL=http://localhost:9000
SONARQUBE_TOKEN=

# OWASP ZAP security scanning
ZAP_URL=http://localhost:8080
ZAP_API_KEY=

# Pact contract testing
PACT_BROKER_URL=
PROVIDER_BASE_URL=

# WebPageTest performance testing
WPT_SERVER=http://localhost:4000

# Appium mobile testing
APPIUM_HOST=localhost
APPIUM_PORT=4723

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================
# Skip API authentication (NEVER set to true in production!)
SKIP_API_AUTH=false

# Require API auth even in development
REQUIRE_API_AUTH=false

# Force development mode
NODE_ENV=development
