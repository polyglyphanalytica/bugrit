rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Projects - users can only access their own projects
    match /projects/{projectId} {
      allow read, write: if isAuthenticated() &&
        (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
    }

    // Scans - users can access scans for their projects
    match /scans/{scanId} {
      allow read, write: if isAuthenticated();
    }

    // Scan test cases
    match /scanTestCases/{docId} {
      allow read, write: if isAuthenticated();
    }

    // Scan issues
    match /scanIssues/{docId} {
      allow read, write: if isAuthenticated();
    }

    // Reports
    match /reports/{reportId} {
      allow read, write: if isAuthenticated();
    }

    // Organizations - members can read, admins can write
    match /organizations/{orgId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // API Keys - users can manage their own keys
    match /apiKeys/{keyId} {
      allow read, write: if isAuthenticated();
    }

    // Test cases, runs, scripts
    match /testCases/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /testRuns/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /testScripts/{docId} {
      allow read, write: if isAuthenticated();
    }

    // Executions
    match /executions/{docId} {
      allow read, write: if isAuthenticated();
    }

    // Workers and Jobs - system collections
    match /workers/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // Server-side only
    }

    match /jobs/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // Server-side only
    }

    // Stats - read only for authenticated users
    match /stats/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // Server-side only
    }
  }
}
